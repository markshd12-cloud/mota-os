# ─────────────────────────────────────────────────────────────────────────────
# .env.example — TEMPLATE público (versionado no git).
# Copie para .env.local e preencha com valores reais.
# Nunca comite .env.local nem cole valores reais aqui.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Anthropic (Claude) via WIF / Auth0 ──────────────────────────────────────
# SERVER-SIDE ONLY. Sem API key estática — autenticação via Workload Identity
# Federation. O script scripts/refresh-anthropic-token.mjs troca client_credentials
# Auth0 por um JWT e grava em ANTHROPIC_IDENTITY_TOKEN_FILE.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

ANTHROPIC_IDENTITY_TOKEN_FILE=tmp/anthropic-token
ANTHROPIC_FEDERATION_RULE_ID=fdrl_
ANTHROPIC_ORGANIZATION_ID=
ANTHROPIC_SERVICE_ACCOUNT_ID=svac_
ANTHROPIC_WORKSPACE_ID=wrkspc_

# Em GitHub Actions/Coolify: omitir ANTHROPIC_IDENTITY_TOKEN_FILE acima e usar:
# ANTHROPIC_IDENTITY_TOKEN_FILE=/var/run/secrets/anthropic.com/token

# ─── URL pública da aplicação ────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── OpenAI GPT — OAuth (Device Code / Codex) ────────────────────────────────
# Fluxo PKCE sem API key. Opcional se OPENAI_API_KEY estiver configurada.
OPENAI_OAUTH_CLIENT_ID=app_
OPENAI_OAUTH_AUTHORIZE_URL=https://auth.openai.com/authorize
OPENAI_OAUTH_DEVICE_CODE_URL=https://auth.openai.com/oauth/device/code
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_CODEX_RESPONSES_URL=https://chatgpt.com/backend-api/codex/responses
OPENAI_OAUTH_SCOPES=openid profile email offline_access api.connectors.read api.connectors.invoke
OPENAI_OAUTH_ORIGINATOR=codex_cli_rs
OPENAI_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/gpt/callback

# ─── OpenAI GPT — API Key (alternativa) ──────────────────────────────────────
# Se preenchida, tem precedência sobre o fluxo OAuth/Codex.
# Obter em: https://platform.openai.com/api-keys (formato sk-proj-...)
OPENAI_API_KEY=

# ─── DeepSeek via API Key ────────────────────────────────────────────────────
# Obter em: https://platform.deepseek.com/api_keys (formato sk-...)
# ATENÇÃO: NÃO cole aqui chaves Google (AIza...) — é provedor diferente.
DEEPSEEK_API_KEY=

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Prioridade no servidor: GEMINI_API_KEY > GOOGLE_SERVICE_ACCOUNT_KEY > OAuth do usuário
# GEMINI_API_KEY= (opcional — só se quiser override estático)

# OAuth de usuário (botão "Entrar Google" no chat):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT=

# Service Account JSON (string única, sem quebras de linha): cole o JSON inteiro
# entre aspas duplas. Aceita também base64 do JSON.
GOOGLE_SERVICE_ACCOUNT_KEY=

# ─── Rocket.Chat ─────────────────────────────────────────────────────────────
ROCKETCHAT_URL=https://rocketchat.example.com
ROCKETCHAT_USER_ID=
ROCKETCHAT_AUTH_TOKEN=
ROCKETCHAT_WEBHOOK_URL=

# ─── Webhooks de entrada (POST de provedores externos para nós) ──────────────
# Secret simples no header (compatibilidade). Defina e configure no provedor.
JARVIS_WEBHOOK_SECRET=
GURU_WEBHOOK_SECRET=
# HMAC-SHA256 da Guru (recomendado — mais seguro que secret no header).
# Configure no painel da Guru: Settings → Webhooks → Secret key.
GURU_HMAC_SECRET=

# ─── Supabase ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vai para o bundle do browser. NUNCA coloque o service_role aqui.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_

# SERVER-SIDE ONLY — bypass RLS. NÃO USAR em Client Components nem em código
# que roda no browser. Vazamento desta chave dá controle total do banco.
SUPABASE_SERVICE_ROLE_KEY=

